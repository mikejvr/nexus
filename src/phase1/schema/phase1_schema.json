{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase-1 Shard Schema",
  "type": "object",
  "additionalProperties": false,

  "required": [
    "asset_id",
    "extractor",
    "extractor_version",
    "schema_version",
    "metadata",
    "payload",
  ],

  "properties": {
    "asset_id": {
      "type": "string"
    },

    "extractor": {
      "type": "string"
    },

    "extractor_version": {
      "type": "string"
    },

    "schema_version": {
      "type": "integer"
    },

    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["normalized_hash"],
      "properties": {
        "normalized_hash": {
          "type": "string"
        }
      }
    },

    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
