### `run_extractor.py` — single‑file entrypoint

```python
from __future__ import annotations
from pathlib import Path
from typing import Dict

from .extractor_registry import select_extractor


def run_extractor_for_file(path: Path, root: Path) -> Dict[str, object]:
    """
    Pure, deterministic wrapper:
      - selects extractor
      - runs extraction
      - returns schema-aligned dict
    """
    extractor = select_extractor(path)
    output = extractor.extract(path, root)
    return output.to_dict()
