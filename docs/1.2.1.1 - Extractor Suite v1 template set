### `binary_extractor.py` — minimal “catch‑all” extractor

```python
from __future__ import annotations
from pathlib import Path

from .base_extractor import BaseExtractor


class BinaryExtractor(BaseExtractor):
    """
    Fallback extractor for unknown/opaque files.
    Structural only: size + content hash + type tag.
    """

    @property
    def name(self) -> str:
        return "binary"

    def detect_file_type(self, path: Path) -> str:
        # Deterministic, non-heuristic classification.
        # For Phase-1, we keep this minimal and structural.
        suffix = path.suffix.lower()

        if suffix == ".bin":
            return "application/octet-stream"
        # Fallback NEXUS canonical type
        return "nexus/binary"
