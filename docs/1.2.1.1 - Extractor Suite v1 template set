### `extractor_types.py` — shared types & helpers

```python
from __future__ import annotations
from dataclasses import dataclass, asdict
from pathlib import Path
from typing import Dict
import hashlib

# -----------------------------
# Canonical extractor output
# -----------------------------
@dataclass(frozen=True)
class ExtractorOutput:
    asset_id: str          # content hash (sha256)
    source_path: str       # relative path
    file_type: str         # canonical type (MIME or NEXUS type)
    size_bytes: int        # file size in bytes
    hash_sha256: str       # same as asset_id
    extractor: str         # extractor name
    extractor_version: str # semver

    def to_dict(self) -> Dict[str, object]:
        return asdict(self)


# -----------------------------
# Deterministic helpers
# -----------------------------
def compute_content_sha256(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(8192), b""):
            h.update(chunk)
    return h.hexdigest()


def compute_size_bytes(path: Path) -> int:
    # Uses file length only; no timestamps, no metadata beyond size.
    return path.stat().st_size


def to_relative_path(path: Path, root: Path) -> str:
    # POSIX, relative, deterministic
    return path.relative_to(root).as_posix()
```

