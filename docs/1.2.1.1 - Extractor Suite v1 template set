### `extractor_registry.py` — deterministic routing

```python
from __future__ import annotations
from pathlib import Path
from typing import Dict, Type

from .base_extractor import BaseExtractor
from .binary_extractor import BinaryExtractor
from .text_extractor import TextExtractor

# Deterministic registry; order does not affect behavior.
_EXTRACTORS: Dict[str, BaseExtractor] = {
    "text": TextExtractor(),
    "binary": BinaryExtractor(),
}


def select_extractor(path: Path) -> BaseExtractor:
    """
    Deterministic extractor selection based on extension only.
    No heuristics, no content sniffing.
    """
    suffix = path.suffix.lower()

    if suffix in {".txt", ".log", ".md", ".csv"}:
        return _EXTRACTORS["text"]

    # Fallback
    return _EXTRACTORS["binary"]
