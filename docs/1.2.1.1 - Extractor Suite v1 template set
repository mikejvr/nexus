### `text_extractor.py` — deterministic text classifier

```python
from __future__ import annotations
from pathlib import Path

from .base_extractor import BaseExtractor


class TextExtractor(BaseExtractor):
    """
    Text extractor: structural only.
    Does NOT parse semantics, encoding heuristics, or content.
    """

    @property
    def name(self) -> str:
        return "text"

    def detect_file_type(self, path: Path) -> str:
        suffix = path.suffix.lower()

        if suffix in {".txt", ".log"}:
            return "text/plain"
        if suffix in {".md"}:
            return "text/markdown"
        if suffix in {".csv"}:
            return "text/csv"

        # Fallback NEXUS canonical type for text-like files
        return "nexus/text-structural"
