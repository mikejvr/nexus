### `base_extractor.py` — abstract extractor contract

```python
from __future__ import annotations
from abc import ABC, abstractmethod
from pathlib import Path
from typing import Final

from .extractor_types import (
    ExtractorOutput,
    compute_content_sha256,
    compute_size_bytes,
    to_relative_path,
)

EXTRACTOR_VERSION: Final[str] = "1.0.0"  # bump only via constitutional change


class BaseExtractor(ABC):
    """
    Pure, stateless, deterministic extractor.
    """

    @property
    @abstractmethod
    def name(self) -> str:
        """Canonical extractor name (e.g., 'binary', 'text')."""

    @abstractmethod
    def detect_file_type(self, path: Path) -> str:
        """
        Return canonical file_type:
          - MIME type, or
          - NEXUS canonical type (Appendix A)
        Must be deterministic, no heuristics, no environment dependence.
        """

    def extract(self, path: Path, root: Path) -> ExtractorOutput:
        """
        Main entrypoint: given an absolute path and intake root,
        return a fully-populated ExtractorOutput.
        """
        content_hash = compute_content_sha256(path)
        size = compute_size_bytes(path)
        rel_path = to_relative_path(path, root)
        file_type = self.detect_file_type(path)

        return ExtractorOutput(
            asset_id=content_hash,
            source_path=rel_path,
            file_type=file_type,
            size_bytes=size,
            hash_sha256=content_hash,
            extractor=self.name,
            extractor_version=EXTRACTOR_VERSION,
        )
